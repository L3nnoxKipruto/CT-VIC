<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DataEntryApp.ViewModels"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="DataEntryApp.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="RadiologyDMS"
        Background="{StaticResource MainBackgroundBrush}"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="260,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <DockPanel Margin="0,20">
                <!-- Branding -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="24,0,24,40">
                    <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource TealPrimaryBrush}">
                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="White" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="RadiologyDMS" Foreground="White" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <ListBox Background="Transparent" BorderThickness="0" 
                         ItemsSource="{Binding MenuItems}"
                         SelectedItem="{Binding SelectedMenuItem}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="24,12" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#E2E8F0" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="Margin" Value="12,2" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="#1B232D" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="#1B232D" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="20"/>
                                <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Profile (Bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="24,0" Spacing="10">
                    <Separator Background="#1AFFFFFF"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource TealPrimaryBrush}">
                            <TextBlock Text="DR" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Dr. Smith" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Staff Radiologist" Foreground="Gray" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <DockPanel Grid.Column="1">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Height="72" Background="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="List" Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedMenuItem.Header}" FontSize="18" FontWeight="SemiBold" Foreground="#1A1C1E"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="25" VerticalAlignment="Center">
                        <Border Background="#F3F5F7" CornerRadius="20" Padding="15,8" Width="300">
                            <Grid ColumnDefinitions="Auto,*">
                                <ui:SymbolIcon Symbol="Find" FontSize="16" Foreground="Gray" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Watermark="Search records..." BorderThickness="0" Background="Transparent" Padding="0"/>
                            </Grid>
                        </Border>
                        <ui:SymbolIcon Symbol="Message" Foreground="Gray" FontSize="20"/>
                        <ui:SymbolIcon Symbol="Setting" Foreground="Gray" FontSize="20"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content -->
            <TransitioningContentControl Content="{Binding CurrentPage}" Margin="0">
                <TransitioningContentControl.PageTransition>
                    <PageSlide Duration="0:0:0.4" Orientation="Vertical" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </DockPanel>
    </Grid>
</Window>
