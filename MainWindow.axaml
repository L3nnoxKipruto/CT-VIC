<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DataEntryApp.ViewModels"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="DataEntryApp.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="RadiologyDMS"
        Background="{StaticResource MainBackgroundBrush}"
        MinWidth="1200" MinHeight="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Main Application Content -->
        <Grid ColumnDefinitions="260,*" IsVisible="{Binding !IsInitializing}">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
                <DockPanel Margin="0,20">
                    <!-- Branding -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="15" Margin="24,0,24,40">
                        <Border Width="40" Height="40" CornerRadius="10" ClipToBounds="True" Background="White">
                            <Image Source="avares://DataEntryApp/Assets/logo.png" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="RadiologyDMS" Foreground="White" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <ListBox Background="Transparent" BorderThickness="0" 
                             ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="24,12" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="#E2E8F0" />
                                <Setter Property="CornerRadius" Value="8" />
                                <Setter Property="Margin" Value="12,2" />
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="#1B232D" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover">
                                <Setter Property="Background" Value="#1B232D" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="20"/>
                                    <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Main Content Area -->
            <DockPanel Grid.Column="1">
                <!-- Header -->
                <Border DockPanel.Dock="Top" Height="72" Background="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="List" Foreground="Gray"/>
                            <TextBlock Text="{Binding SelectedMenuItem.Header}" FontSize="18" FontWeight="SemiBold" Foreground="#1A1C1E"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="25" VerticalAlignment="Center">
                            <Border Background="#F3F5F7" CornerRadius="20" Padding="15,8" Width="300">
                                <Grid ColumnDefinitions="Auto,*">
                                    <ui:SymbolIcon Symbol="Find" FontSize="16" Foreground="Gray" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" Watermark="Search records..." BorderThickness="0" Background="Transparent" Padding="0"/>
                                </Grid>
                            </Border>
                            <ui:SymbolIcon Symbol="Message" Foreground="Gray" FontSize="20"/>
                            <ui:SymbolIcon Symbol="Setting" Foreground="Gray" FontSize="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <TransitioningContentControl Content="{Binding CurrentPage}" Margin="0">
                    <TransitioningContentControl.PageTransition>
                        <PageSlide Duration="0:0:0.4" Orientation="Vertical" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </DockPanel>
            
            <!-- Global Notification Overlay -->
            <Border Grid.Column="1" 
                    DataContext="{Binding Notification}"
                    IsVisible="{Binding IsVisible}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                    Margin="30" Width="350"
                    Classes="dms-card"
                    Background="White"
                    BoxShadow="0 10 25 0 #20000000">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Width="4" CornerRadius="2" VerticalAlignment="Stretch" Margin="-24,-24,15,-24"
                            Background="{Binding Type, Converter={StaticResource StatusToColorConverter}}"/>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Splash Screen Overlay -->
        <Panel IsVisible="{Binding IsInitializing}" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="30">
                <Image Source="avares://DataEntryApp/Assets/logo.png" Width="200" Height="200">
                    <Image.Styles>
                        <Style Selector="Image">
                            <Style.Animations>
                                <Animation Duration="0:0:2" IterationCount="Infinite">
                                    <KeyFrame KeyTime="0:0:0">
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="ScaleTransform.ScaleX" Value="0.95"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="0.95"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:1">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Setter Property="ScaleTransform.ScaleX" Value="1.05"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="1.05"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:2">
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="ScaleTransform.ScaleX" Value="0.95"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="0.95"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Image.Styles>
                </Image>
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Foreground="{StaticResource TealPrimaryBrush}"/>
                <TextBlock Text="Initializing Clinical Data System..." HorizontalAlignment="Center" Foreground="#64748B" FontSize="14" FontWeight="Medium"/>
            </StackPanel>
        </Panel>
    </Grid>
</Window>
